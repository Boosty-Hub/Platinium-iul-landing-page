# ── Frontend (Vite) ──────────────────────────────────────────────
# La publishable key es PÚBLICA por diseño (va en el bundle del cliente).
# La seguridad real es RLS + least-privilege + guards, no esconder esta key.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# ── Solo local (NO commitear — va en .env.local) ─────────────────
# Management API personal access token. Poder total sobre la cuenta.
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SUPABASE_PROJECT_REF=<project-ref>
